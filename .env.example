# ─────────────────────────────────────────────────────────────────────────────
# Hunting Goals / TrendSpy — Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are OPTIONAL — the app runs with graceful fallbacks.
# ─────────────────────────────────────────────────────────────────────────────

# ── Where to place this file ──────────────────────────────────────────────────
# Backend (server.js + Next.js API routes): copy to  backend/.env.local
# Frontend (Vite): copy to frontend/.env.local  (VITE_* vars only)
# On Replit: add all variables as Replit Secrets instead of using .env files

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret. Required in production — without it all sessions are
# invalidated on every server restart.
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. Leave blank to use in-memory MongoDB (dev).
# Data resets on every restart without this.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/trendspy?retryWrites=true&w=majority
DB_NAME=trendspy

# ── AI Analysis ───────────────────────────────────────────────────────────────
# Groq API key for real LLM-powered product analysis.
# Get one free at https://console.groq.com
# Without this, the AI Analyst page uses a local rule-based fallback.
GROQ_API_KEY=gsk_...

# ── Facebook Ad Scraping ──────────────────────────────────────────────────────
# Your Facebook session cookie for the Ad Library scraper.
# Without this, the scraper runs unauthenticated and returns very few results.
# Format: "c_user=XXXXX; xs=XXXXX; ..."
FB_SESSION_COOKIE=

# ── Email Alerts ──────────────────────────────────────────────────────────────
# Gmail App Password (not your regular Gmail password).
# Required for email alert delivery. Set up at myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ── WhatsApp Alerts (Green API) ───────────────────────────────────────────────
# Green API credentials for WhatsApp notifications.
# Sign up at https://green-api.com
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret key for admin-only API endpoints.
ADMIN_API_KEY=

# ── Internal Services ─────────────────────────────────────────────────────────
# Shared secret between the backend API and socket server.
# Required in production; auto-set in development.
SOCKET_INTERNAL_SECRET=your_socket_secret_here

# ── Feature Flags ─────────────────────────────────────────────────────────────
ALERTS_ENABLED=true
TIKTOK_SANDBOX_MODE=true

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are prefixed VITE_ and exposed to the browser bundle.
VITE_APP_URL=http://localhost:5000
# VITE_API_URL=http://localhost:3001  # Leave blank — Vite proxies /api to 3001
