# ─────────────────────────────────────────────────────────────────────────────
# Hunting Goals / TrendSpy — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment Options ──────────────────────────────────────────────────────
# Option A: Quick Start (In-Memory Database)
# Option B: Production Ready (Full Feature Set)

# ════════════════════════════════════════════════════════════════════════════
# OPTION A — QUICK START CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=dev_secret_2026_please_change_in_production

# ── Database ────────────────────────────────────────────────────────────────
# Leave empty — uses embedded database for testing
MONGODB_URI=
DB_NAME=trendspy_quickstart

# ── AI Services ─────────────────────────────────────────────────────────────
# No API key required — uses built-in analysis engine
GROQ_API_KEY=

# ── External Integrations ──────────────────────────────────────────────────
FB_SESSION_COOKIE=
EMAIL_USER=
EMAIL_PASS=
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ── Security Keys ──────────────────────────────────────────────────────────
ADMIN_API_KEY=dev_admin_123456
SOCKET_INTERNAL_SECRET=socket_dev_789012

# ── Feature Controls ────────────────────────────────────────────────────────
ALERTS_ENABLED=false
TIKTOK_SANDBOX_MODE=true

# ── Frontend Configuration ─────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5000

# ════════════════════════════════════════════════════════════════════════════
# OPTION B — PRODUCTION CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# ── Authentication ──────────────────────────────────────────────────────────
# Generate using: openssl rand -base64 32
JWT_SECRET=YOUR_32_CHAR_PRODUCTION_SECRET_HERE

# ── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/trendspy
DB_NAME=trendspy_prod

# ── AI Services ─────────────────────────────────────────────────────────────
# Get your key at console.groq.com
GROQ_API_KEY=gsk_your_actual_groq_api_key_here

# ── Facebook Integration ────────────────────────────────────────────────────
# Required for full ad library access
# Format: "c_user=xxxxx; xs=xxxxx; fr=xxxxx"
FB_SESSION_COOKIE=your_facebook_session_cookie_here

# ── Email Notifications ────────────────────────────────────────────────────
# Gmail App Password — create at myaccount.google.com/apppasswords
EMAIL_USER=your_business_email@gmail.com
EMAIL_PASS=16_char_app_password_here

# ── WhatsApp Notifications ────────────────────────────────────────────────
# Green API credentials
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_api_token_here

# ── Security Keys ──────────────────────────────────────────────────────────
ADMIN_API_KEY=strong_admin_key_$(openssl rand -base64 16)
SOCKET_INTERNAL_SECRET=strong_socket_secret_$(openssl rand -base64 16)

# ── Feature Controls ────────────────────────────────────────────────────────
ALERTS_ENABLED=true
TIKTOK_SANDBOX_MODE=false

# ── Frontend Configuration ─────────────────────────────────────────────────
VITE_APP_URL=https://yourdomain.com

# ════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ════════════════════════════════════════════════════════════════════════════

# 1. Copy this entire file to your backend directory as .env.local
# 2. Choose either Option A or Option B
# 3. Comment out the unused option
# 4. Fill in all required values for your chosen option
# 5. Run: npm start

# For frontend environment:
# - Copy only the VITE_* variables to frontend/.env.local
# - All other variables are backend-only

# ════════════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ════════════════════════════════════════════════════════════════════════════

# If you see "MongoDB connection error" with Option A:
# - This is expected — the app automatically falls back to in-memory storage
# - Your data will reset when the server restarts

# If AI Analysis shows "fallback mode":
# - Add your GROQ_API_KEY for full AI capabilities
# - The rule-based engine works but has limited scope

# For Facebook scraping issues:
# - Ensure your FB_SESSION_COOKIE is valid and not expired
# - Format must match: "c_user=value; xs=value; ..." exactly

# Email delivery troubleshooting:
# - Verify Gmail "Less secure app access" is enabled
# - Or use your organization's SMTP server instead of Gmail
