# ─────────────────────────────────────────────────────────
# TrendSpy Frontend — Environment Variables Template
# On Replit, set these in the Secrets panel or .replit [userenv].
# ─────────────────────────────────────────────────────────

# URL where the Vite frontend is served (used in production)
VITE_APP_URL=http://localhost:5000

# Backend API base URL (leave blank — Vite proxies /api to port 3001)
# VITE_API_URL=http://localhost:3001
